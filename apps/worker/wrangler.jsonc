{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "data-analyze-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-14",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "vars": {
    "LLM_BASE_URL": "https://llm.example.com/v1",
    "LLM_MODEL": "unified-model",
    "CF_ACCESS_TEAM_DOMAIN": "replace.cloudflareaccess.com",
    "CF_ACCESS_AUD": "replace-with-access-audience",
    "GITHUB_OWNER": "replace-with-github-owner",
    "GITHUB_REPO": "replace-with-github-repo",
    "GITHUB_BASE_BRANCH": "main"
  },
  "r2_buckets": [
    {
      "binding": "DATA_BUCKET",
      "bucket_name": "data-analyze-data"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "TASK_QUEUE",
        "queue": "data-analyze-tasks"
      }
    ],
    "consumers": [
      {
        "queue": "data-analyze-tasks",
        "max_retries": 2
      }
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "data-analyze-db",
      "database_id": "00000000-0000-0000-0000-000000000001",
      "migrations_dir": "migrations"
    }
  ]
}
